# Required for AI-assisted extraction.
OPENAI_API_KEY=

# Optional for internal/debug testing. Comma-separated named tester keys.
# Testers can enter an assigned key in the app's Settings screen.
# Example: kit:random-token,sierra:another-random-token
SUPPERSTACK_TESTER_KEYS=

# Recommended for closed testing to avoid manually creating per-tester keys.
# Set this on the backend and build the closed-test AAB with the same value as
# EXPO_PUBLIC_SUPPERSTACK_CLOSED_TEST_ACCESS_KEY. The app also sends a stable
# local install ID so each install gets its own import ledger.
SUPPERSTACK_CLOSED_TEST_ACCESS_KEY=

# Optional. Defaults to gpt-4.1-mini.
OPENAI_MODEL=gpt-4.1-mini

# Optional. Defaults to 8787.
PORT=8787

# Optional. Defaults to 8 requests per minute per client IP.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=8

# Optional. Defaults to 25 successful extractions per tester per UTC day.
# This is enforced from the SQLite usage database and survives server restarts.
DAILY_SUCCESS_LIMIT=25

# Optional. Defaults to observe. Use off, observe, or enforce.
MODERATION_MODE=observe
OPENAI_MODERATION_MODEL=omni-moderation-latest
MODERATION_BLOCK_CATEGORIES=sexual/minors,self-harm/instructions,violence/graphic
MODERATION_BLOCK_SCORE=0.85

# Optional. Comma-separated browser origins allowed for CORS preflight.
# Mobile app requests do not need browser CORS.
SUPPERSTACK_ALLOWED_ORIGINS=

# Optional. Prompt-size safety caps for hosted/internal testing.
MAX_PAGE_TEXT_CHARS=10000
MAX_JSON_LD_CHARS=6000
MAX_FETCH_REDIRECTS=4
MAX_HTML_BYTES=1000000
FETCH_TIMEOUT_MS=15000

# Optional. SQLite database path for usage stats.
SUPPERSTACK_USAGE_DB_PATH=/data/usage.sqlite

# Optional. SQLite database path for import balances and purchase records.
SUPPERSTACK_BILLING_DB_PATH=/data/billing.sqlite

# Optional. Defaults to 5 starter recipe imports per tester/user.
SUPPERSTACK_STARTER_IMPORTS=5

# Required for real Google Play purchase/subscription verification.
SUPPERSTACK_GOOGLE_PLAY_PACKAGE_NAME=com.etharialle.serenity.supperstack
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=

# Local development only. Keep false or unset for closed testing and production.
SUPPERSTACK_ENABLE_MOCK_BILLING=false
SUPPERSTACK_ALLOW_UNVERIFIED_PURCHASES=false

# Required for the protected usage dashboard at /admin/usage.
SUPPERSTACK_DASHBOARD_USERNAME=
SUPPERSTACK_DASHBOARD_PASSWORD=
